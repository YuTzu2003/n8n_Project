      "parameters": {
        "jsCode": "const raw = $node[\"Code3\"].json.attendees;\n\nconst attendees = Array.isArray(raw)\n  ? raw.filter(e => e.includes('@'))\n  : (raw || '').split(',').map(e => e.trim()).filter(e => e.includes('@'));\n\nreturn [{ json: { attendees } }];"
